# QuantMind 环境变量模板
# 复制为 .env 并填入真实值（.env 已在 .gitignore 中，不会提交）

# LLM Provider: DeepSeek (OpenAI-compatible)
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com
LLM_FAST=deepseek-v4-flash       # DeepSeek V4 Flash（非思考模式）
LLM_STRONG=deepseek-v4-pro       # DeepSeek V4 Pro（思考模式，49B active）

# Embeddings: 本地 fastembed（无需 API key）
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5   # 768-dim; 切换后需 --recreate-collections
EMBEDDING_DIM=768

# LangSmith (tracing + eval) — 注意：账号在 APAC 区需用 apac endpoint
LANGSMITH_API_KEY=lsv2_pt_...
LANGSMITH_ENDPOINT=https://apac.api.smith.langchain.com   # APAC 区；美国区用 https://api.smith.langchain.com
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=quantmind

# Qdrant (local Docker)
QDRANT_HOST=localhost
QDRANT_PORT=6333

# PostgreSQL (local Docker)
POSTGRES_URL=postgresql://quantmind:quantmind@localhost:5432/quantmind

# Streamlit → FastAPI (local dev; use http://api:8000 when Streamlit runs in Docker network)
QUANTMIND_API_URL=http://localhost:8000
